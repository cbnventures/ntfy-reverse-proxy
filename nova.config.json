{
  "project": {
    "name": {
      "title": "Reverse Proxy for ntfy",
      "slug": "ntfy-reverse-proxy"
    },
    "description": {
      "short": "Notification gateway on Cloudflare Workers that routes webhooks and emails to ntfy with automatic server failover",
      "long": "Webhook and email notification gateway with built-in interpreters (Statuspage.io, Synology DSM, Seerr, pfSense, UniFi, ntfy JSON, plain text), automatic primary/fallback server failover, and smart message splitting, powered by Cloudflare Workers and Cloudflare Email Routing. Interactive CLI for configuration, validation, and deployment."
    },
    "keywords": [
      "ntfy",
      "reverse-proxy",
      "cloudflare-workers",
      "webhooks",
      "notifications",
      "statuspage",
      "synology",
      "seerr",
      "pfsense",
      "unifi"
    ],
    "legalName": "CBN Ventures LLC",
    "pronouns": "business",
    "platforms": [
      "nodejs"
    ],
    "startingYear": 2023,
    "license": "MIT"
  },
